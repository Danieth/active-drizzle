"// AUTO-GENERATED — do not edit manually
import { Asset as _Asset } from './Asset.model.js'
import { Business as _Business } from './Business.model.js'
import { Campaign as _Campaign } from './Campaign.model.js'

class AssetClient {
  id: number;
  assetType: number | null;
  title: string | null;
  businessId: number;
  createdAt: Date;
  updatedAt: Date;
  business: BusinessClient | null;
  campaigns: CampaignClient[];
  private _initial: any;
  constructor(payload: Record<string, any> = {}) {
    this.id = payload.id ?? null;
    this.assetType = payload.assetType ?? null;
    this.title = payload.title ?? null;
    this.businessId = payload.businessId ?? null;
    this.createdAt = payload.createdAt ?? null;
    this.updatedAt = payload.updatedAt ?? null;
    this.business = payload.business ? new ((_Business as any).Client)(payload.business) : null;
    this.campaigns = (payload.campaigns || []).map((i: any) => new ((_Campaign as any).Client)(i));
    this._initial = JSON.parse(JSON.stringify(this.toJSON()));
  }

  assetFormat(): string | null {
    
            if (this.isImages()) return 'image'
            if (this.isVideos()) return 'video'
            return null
          
  }
  toJSON(): Record<string, unknown> {
    const out: Record<string, unknown> = {};
    out.id = (this as any).id;
    out.assetType = (this as any).assetType;
    out.title = (this as any).title;
    out.businessId = (this as any).businessId;
    out.createdAt = (this as any).createdAt;
    out.updatedAt = (this as any).updatedAt;
    return out;
  }

  isChanged(): boolean {
    return JSON.stringify(this.toJSON()) !== JSON.stringify(this._initial);
  }

  restoreAttributes(): void {
    Object.assign(this, JSON.parse(JSON.stringify(this._initial)));
  }

  validate(path = ''): Record<string, string[]> {
    let errors: Record<string, string[]> = {};
    const _push = (field: string, msg: unknown) => {
      if (typeof msg !== 'string') return;
      const t = msg.trim();
      if (!t) return;
      (errors[field] = errors[field] || []).push(t);
    };
    const _run = (field: string, validators: any, value: any) => {
      const list = Array.isArray(validators) ? validators : [validators];
      for (const fn of list) {
        if (typeof fn !== 'function') continue;
        try { _push(field, fn(value, this, field)); } catch (e) {
          if (typeof process !== 'undefined' && process.env?.NODE_ENV !== 'production') {
            console.warn('[active-drizzle] validator for "' + field + '" threw client-side (treated as server-only):', e);
          }
        }
      }
    };
    if ((this as any).business) {
      errors = { ...errors, ...(this as any).business.validate(path ? \`\${path}.business\` : 'business') };
    }
    ((this as any).campaigns as any[] || []).forEach((item: any, i: number) => {
      errors = { ...errors, ...item.validate(path ? \`\${path}.campaigns.\${i}\` : \`campaigns.\${i}\`) };
    });
    return errors;
  }
}

// Attach so that new Asset.Client(payload) works at runtime
;(_Asset as any).Client = AssetClient

